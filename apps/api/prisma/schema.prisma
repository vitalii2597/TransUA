generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum TripStatus {
  SCHEDULED
  BOARDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

enum PaymentMethod {
  CARD
  BLIK
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  phone         String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(PASSENGER)
  preferredLang String   @default("uk")
  createdAt     DateTime @default(now())

  refreshTokens RefreshToken[]
  bookings      Booking[]
  vehicles      Vehicle[]
  driverTrips   Trip[]        @relation("DriverTrips")
  payments      Payment[]
  parcelOrders  ParcelOrder[]
}

model Route {
  id                 String  @id @default(uuid())
  originCountry      String
  destinationCountry String
  originCity         String
  destinationCity    String
  durationHours      Int
  active             Boolean @default(true)

  trips Trip[]
}

model Vehicle {
  id          String  @id @default(uuid())
  driverId    String
  driver      User    @relation(fields: [driverId], references: [id])
  plateNumber String
  model       String
  capacity    Int
  active      Boolean @default(true)

  trips Trip[]
}

model Trip {
  id          String     @id @default(uuid())
  fromCity    String
  toCity      String
  departureAt DateTime
  arrivalAt   DateTime
  priceUah    Int
  totalSeats  Int
  status      TripStatus @default(SCHEDULED)
  createdAt   DateTime   @default(now())

  routeId   String?
  route     Route?   @relation(fields: [routeId], references: [id])
  driverId  String?
  driver    User?    @relation("DriverTrips", fields: [driverId], references: [id])
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  bookings     Booking[]
  parcelOrders ParcelOrder[]
}

model Payment {
  id           String        @id @default(uuid())
  payerId      String
  payer        User          @relation(fields: [payerId], references: [id])
  amount       Float
  currency     String        @default("UAH")
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  providerTxId String?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())

  bookings Booking[]
}

model Booking {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  tripId         String
  trip           Trip          @relation(fields: [tripId], references: [id])
  seatNumber     Int
  passengerName  String
  status         BookingStatus @default(CONFIRMED)
  createdAt      DateTime      @default(now())

  pickupAddress  String?
  dropoffAddress String?
  luggageKg      Float?
  paymentId      String?
  payment        Payment?      @relation(fields: [paymentId], references: [id])

  passengers BookingPassenger[]

  @@unique([tripId, seatNumber])
}

model BookingPassenger {
  id             String  @id @default(uuid())
  bookingId      String
  booking        Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fullName       String
  documentNumber String?
  phone          String?
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum ParcelStatus {
  PENDING_PICKUP
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  RETURNED
}

model ParcelOrder {
  id              String       @id @default(uuid())
  senderId        String
  sender          User         @relation(fields: [senderId], references: [id])
  tripId          String?
  trip            Trip?        @relation(fields: [tripId], references: [id])
  pickupAddress   String
  deliveryAddress String
  recipientName   String
  recipientPhone  String
  weightKg        Float
  description     String?
  status          ParcelStatus @default(PENDING_PICKUP)
  trackingCode    String       @unique
  priceEur        Float
  createdAt       DateTime     @default(now())

  statusLogs ParcelStatusLog[]
}

model ParcelStatusLog {
  id        String       @id @default(uuid())
  parcelId  String
  parcel    ParcelOrder  @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  status    ParcelStatus
  location  String?
  note      String?
  loggedAt  DateTime     @default(now())
}
